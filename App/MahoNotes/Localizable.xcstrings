    "This collection and all its notes will be moved to the Trash.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This collection and all its notes will be moved to the Trash."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此收藏集及其所有筆記將移至垃圾桶。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このコレクションとすべてのノートがゴミ箱に移動されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 컬렉션과 모든 노트가 휴지통으로 이동됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette collection et toutes ses notes seront déplacées dans la corbeille."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa raccolta e tutte le sue note saranno spostate nel Cestino."
          }
