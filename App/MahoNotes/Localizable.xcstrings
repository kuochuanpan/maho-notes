    "Merge combines both sets of vaults.\nConflicting names will be renamed with a device suffix." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge combines both sets of vaults.\nConflicting names will be renamed with a device suffix."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fusionar combina ambos conjuntos de bóvedas.\nLos nombres en conflicto se renombrarán con un sufijo del dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fusion combine les deux ensembles de coffres.\nLes noms en conflit seront renommés avec un suffixe d'appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unisci combina entrambi gli insiemi di archivi.\nI nomi in conflitto verranno rinominati con un suffisso del dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マージは両方の保管庫を統合します。\n名前が衝突する場合はデバイス名を末尾に付けてリネームします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "병합은 양쪽 보관함을 모두 합칩니다.\n이름이 충돌하면 기기 접미사를 붙여 이름을 바꿉니다."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "合併會將兩邊的保管庫整合在一起。\n名稱衝突時會加上裝置後綴重新命名。"
          }
        }
      }
    },
    "Merge combines both sets of vaults.\\nConflicting names will be renamed with a device suffix." : {
