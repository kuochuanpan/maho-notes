    "Semantic search uses an on-device embedding model that requires %@ of memory. This runs in the background and won't affect app responsiveness.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Semantic search uses an on-device embedding model that requires %@ of memory. This runs in the background and won't affect app responsiveness."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セマンティック検索は %@ のメモリを必要とするデバイス上の埋め込みモデルを使用します。バックグラウンドで実行され、アプリの応答性には影響しません。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語意搜尋使用需要 %@ 記憶體的裝置端嵌入模型。這會在背景執行，不影響 App 的回應速度。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "의미 검색은 %@의 메모리가 필요한 기기 내 임베딩 모델을 사용합니다. 백그라운드에서 실행되며 앱 응답성에 영향을 주지 않습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La recherche sémantique utilise un modèle d'embedding local nécessitant %@ de mémoire. Il s'exécute en arrière-plan sans affecter la réactivité de l'app."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La ricerca semantica utilizza un modello di embedding locale che richiede %@ di memoria. Viene eseguito in background senza influire sulla reattività dell'app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La búsqueda semántica usa un modelo de embedding en el dispositivo que requiere %@ de memoria. Se ejecuta en segundo plano sin afectar la capacidad de respuesta de la app."
          }
        }
      }
    }
  }
}
