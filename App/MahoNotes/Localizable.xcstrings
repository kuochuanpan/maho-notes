    "Merge combines both sets of vaults.\\nConflicting names will be renamed with a device suffix.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Merge combines both sets of vaults.\\nConflicting names will be renamed with a device suffix."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "合併會結合兩組保管庫。\n名稱衝突的保管庫會加上裝置後綴。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マージすると両方の保管庫が統合されます。\n名前が競合する場合はデバイス名が付加されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "병합하면 양쪽 보관함이 합쳐집니다.\n이름이 겹치면 기기 접미사가 붙습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La fusion combine les deux ensembles de coffres.\nLes noms en conflit seront renommés avec un suffixe d'appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'unione combina entrambi i gruppi di archivi.\nI nomi in conflitto saranno rinominati con un suffisso del dispositivo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La fusión combina ambos grupos de bóvedas.\nLos nombres en conflicto se renombrarán con un sufijo del dispositivo."
          }
        }
      }
    },
    "Merged with %lld rename(s):": {
      "extractionState": "manual",
      "localizations": {
