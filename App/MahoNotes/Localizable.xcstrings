    "Click the highlighted  ＋  button\\nto create your first vault.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the highlighted  ＋  button\\nto create your first vault."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊上方醒目的 ＋ 按鈕\n建立你的第一個保管庫。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライトされた ＋ ボタンをクリックして\n最初の保管庫を作成しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "강조 표시된 ＋ 버튼을 클릭하여\n첫 번째 보관함을 만드세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur le bouton ＋ en surbrillance\npour créer votre premier coffre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Clicca sul pulsante ＋ evidenziato\nper creare il tuo primo archivio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en el botón ＋ resaltado\npara crear tu primera bóveda."
          }
        }
      }
    },
